# n8n admin password — choose something strong (min 8 chars)
N8N_PASSWORD=changeme

# From BotFather after creating your bot (looks like: 7234567890:AAFxxxxxxx)
TELEGRAM_BOT_TOKEN=

# Your personal Telegram numeric chat ID (get via @userinfobot)
YOUR_TELEGRAM_CHAT_ID=

# From ocr.space free account — emailed to you after signup
OCR_SPACE_API_KEY=

# The long ID in your Google Sheet URL (between /d/ and /edit)
GOOGLE_SHEET_ID=

# Google Drive folder ID for receipts (from folder URL, after /folders/)
GOOGLE_DRIVE_FOLDER_ID=
